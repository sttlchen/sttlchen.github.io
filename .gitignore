# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ignore the directory for local files during development
local/
tmp/
log/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ingore files created by npm
node_modules
package-lock.json

# Ignore local editor/project metadata
.idea/
.vscode/
.claude/

# Ignore Word source files (only PDFs go in the repo)
files/*.docx
